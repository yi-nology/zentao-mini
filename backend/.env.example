# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# 注意：环境变量优先级高于配置文件

# ==================== 服务器配置 ====================

# 应用类型: http 或 wails
ZENTAO_MINI_SERVER_TYPE=http

# HTTP服务器端口
ZENTAO_MINI_SERVER_PORT=12345

# 读超时时间（秒）
ZENTAO_MINI_SERVER_READ_TIMEOUT=120

# 写超时时间（秒）
ZENTAO_MINI_SERVER_WRITE_TIMEOUT=120

# 优雅关闭超时时间（秒）
ZENTAO_MINI_SERVER_SHUTDOWN_TIMEOUT=30

# ==================== 安全配置 ====================

# 加密密钥（必须设置，用于加密存储的认证信息）
# 生产环境务必修改为强密码！
ZENTAO_MINI_SECURITY_ENCRYPTION_KEY=your-strong-encryption-key-here

# CORS允许的域名（多个域名用逗号分隔）
# 生产环境必须设置，开发环境可以不设置（允许所有来源）
# 示例: ALLOWED_ORIGINS=http://localhost:3000,https://example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== 限流配置 ====================

# 每分钟允许的请求数（默认60）
ZENTAO_MINI_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# 超限后的封禁时长（分钟，默认5）
ZENTAO_MINI_RATE_LIMIT_BLOCK_DURATION_MINUTES=5

# ==================== 日志配置 ====================

# 日志级别: debug, info, warn, error
ZENTAO_MINI_LOG_LEVEL=info

# 日志格式: json（生产环境）, console（开发环境）
ZENTAO_MINI_LOG_FORMAT=console

# 日志输出路径（空表示标准输出）
# ZENTAO_MINI_LOG_OUTPUT_PATH=./logs/app.log

# 是否启用调用者信息
ZENTAO_MINI_LOG_ENABLE_CALLER=true

# 是否启用堆栈跟踪
ZENTAO_MINI_LOG_ENABLE_STACKTRACE=false

# ==================== 应用配置 ====================

# Gin运行模式: debug, release, test
GIN_MODE=debug

# ==================== 禅道配置（可选） ====================
# 如果不使用配置文件上传，可以使用环境变量配置

# 禅道服务器地址
ZENTAO_MINI_ZENTAO_SERVER=http://your-zentao-server.com

# 禅道账号
ZENTAO_MINI_ZENTAO_ACCOUNT=your-account

# 禅道密码
ZENTAO_MINI_ZENTAO_PASSWORD=your-password

# Token刷新间隔（小时）
ZENTAO_MINI_ZENTAO_TOKEN_REFRESH_INTERVAL=12

# 请求超时时间（秒）
ZENTAO_MINI_ZENTAO_REQUEST_TIMEOUT=120

# ==================== 认证配置 ====================

# 认证配置文件路径
ZENTAO_MINI_AUTH_CONFIG_PATH=./auth_config.enc

# 认证数据库路径
ZENTAO_MINI_AUTH_DB_PATH=./auth.db

# ==================== 配置说明 ====================
# 1. 配置优先级：环境变量 > 配置文件 > 默认值
# 2. 环境变量命名规范：使用 ZENTAO_MINI_ 前缀，配置项用下划线连接
#    例如：server.port -> ZENTAO_MINI_SERVER_PORT
# 3. 生产环境建议：
#    - 使用环境变量管理敏感信息（密码、密钥等）
#    - 日志格式设置为 json
#    - 日志级别设置为 info 或 warn
#    - 启用 CORS 白名单
#    - 适当调整限流配置
